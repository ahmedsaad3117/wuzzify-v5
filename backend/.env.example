# Server
PORT=4001
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the Next.js site + admin)
CORS_ORIGINS=http://localhost:3000

# MySQL connection string
DATABASE_URL=mysql://wuzzify:wuzzify@localhost:3306/wuzzify_v5

# Set to true only for managed MySQL that requires TLS
DB_SSL=false

# When true, TypeORM auto-creates/updates tables from the entities.
# Convenient for local dev; keep false in production and run migrations/*.sql instead.
DB_SYNC=true

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Seed admin (created automatically on boot if it does not exist)
ADMIN_EMAIL=admin@wuzzify.ai
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Wuzzify Admin
