# Server
PORT=4001
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the Next.js site + admin)
CORS_ORIGINS=http://localhost:3000

# MySQL connection string
DATABASE_URL=mysql://wuzzify:wuzzify@localhost:3306/wuzzify_v5

# Set to true only for managed MySQL that requires TLS
DB_SSL=false

# When true, TypeORM auto-creates/updates tables from the entities.
# Convenient for local dev; keep false in production and run migrations/*.sql instead.
DB_SYNC=true

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Seed admin (created automatically on boot if it does not exist)
ADMIN_EMAIL=admin@wuzzify.ai
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Wuzzify Admin

# --- External article ingest (n8n / automation) ---
# API key required on POST /articles/ingest (header: x-api-key).
ARTICLES_API_KEY=change-me-articles-ingest-key

# --- Chat (n8n) ---
# Where client chat messages are forwarded (your n8n webhook).
N8N_WEBHOOK_URL=
# Shared secret n8n must send back on /chat/callback (header x-callback-token or body token).
N8N_CALLBACK_TOKEN=change-me-callback-secret
# Public URL of this backend's callback, passed to n8n so it knows where to reply.
# Local: http://localhost:4001/api/v1/chat/callback
CHAT_CALLBACK_URL=http://localhost:4001/api/v1/chat/callback
# Minutes of inactivity before a chat session is dropped from memory.
CHAT_SESSION_TTL_MIN=120
