# ============================================================================
# Wuzzify v5 — deployment configuration
# Copy to `deploy.env` and fill in. Both scripts source this file.
#   cp deploy.env.example deploy.env  &&  nano deploy.env
# ============================================================================

# --- Domains ---------------------------------------------------------------
# Main site (Next.js frontend) and the API subdomain (NestJS backend).
# Both must already point (A record) to this server's public IP.
DOMAIN=example.com
API_DOMAIN=api.example.com
INCLUDE_WWW=true                 # also serve/cert www.${DOMAIN}
LETSENCRYPT_EMAIL=you@example.com

# --- System user ------------------------------------------------------------
# The non-root user that owns the code and runs PM2 (usually your login user).
APP_USER=deploy

# --- Ports (internal; Nginx proxies to these) -------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=4001

# --- PostgreSQL -------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wuzzify_v5
DB_USER=wuzzify
DB_PASSWORD=change-me-strong-password

# --- Backend secrets --------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Seed admin (created on first backend boot if it doesn't exist)
ADMIN_EMAIL=admin@wuzzify.ai
ADMIN_PASSWORD=change-me-admin-password
ADMIN_NAME=Wuzzify Admin

# --- Frontend extras (optional) ---------------------------------------------
# Telegram lead capture used by app/api/contact/route.ts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Node version to install (NodeSource major) -----------------------------
NODE_MAJOR=20
